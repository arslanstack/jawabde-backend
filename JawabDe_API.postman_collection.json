    {
      "name": "Politicians",
      "item": [
        {
          "name": "List Politicians",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/politicians?per_page=20",
              "host": ["{{base_url}}"],
              "path": ["politicians"],
              "query": [{ "key": "per_page", "value": "20" }]
            }
          }
        },
        {
          "name": "Search Politicians by Name",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/politicians?search=imran",
              "host": ["{{base_url}}"],
              "path": ["politicians"],
              "query": [{ "key": "search", "value": "imran" }]
            }
          }
        },
        {
          "name": "Filter by Party",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/politicians?party=PTI",
              "host": ["{{base_url}}"],
              "path": ["politicians"],
              "query": [{ "key": "party", "value": "PTI" }]
            }
          }
        },
        {
          "name": "Filter by Province + Assembly",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/politicians?province=Punjab&assembly=PP",
              "host": ["{{base_url}}"],
              "path": ["politicians"],
              "query": [
                { "key": "province", "value": "Punjab" },
                { "key": "assembly", "value": "PP" }
              ]
            }
          }
        },
        {
          "name": "Get Politician by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/politicians/{{politician_id}}", "host": ["{{base_url}}"], "path": ["politicians", "{{politician_id}}"] }
          }
        }
      ]
    },
