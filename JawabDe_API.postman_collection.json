            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/stats/politician/{{politician_id}}", "host": ["{{base_url}}"], "path": ["stats", "politician", "{{politician_id}}"] }
          }
