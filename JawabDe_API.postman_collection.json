    },
    {
      "name": "Complaints (Protected)",
      "item": [
        {
          "name": "File a Complaint",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.data && r.data.id) pm.collectionVariables.set('complaint_id', r.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "photo", "type": "file", "src": "" },
                { "key": "description", "value": "Large pothole on main road near canal bridge", "type": "text" },
                { "key": "latitude", "value": "31.5497", "type": "text" },
                { "key": "longitude", "value": "74.3436", "type": "text" },
                { "key": "district_id", "value": "{{district_id}}", "type": "text" },
                { "key": "complaint_type_id", "value": "{{complaint_type_id}}", "type": "text" },
                { "key": "term_ids[]", "value": "{{term_id}}", "type": "text" }
              ]
            },
            "url": { "raw": "{{base_url}}/complaints", "host": ["{{base_url}}"], "path": ["complaints"] }
          }
        },
        {
          "name": "My Complaints",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/complaints/mine", "host": ["{{base_url}}"], "path": ["complaints", "mine"] }
          }
        },
        {
          "name": "Get Single Complaint",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/complaints/{{complaint_id}}", "host": ["{{base_url}}"], "path": ["complaints", "{{complaint_id}}"] }
          }
        },
        {
          "name": "Resolve Complaint",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/complaints/{{complaint_id}}/resolve", "host": ["{{base_url}}"], "path": ["complaints", "{{complaint_id}}", "resolve"] }
          }
        },
        {
          "name": "Withdraw Complaint",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{base_url}}/complaints/{{complaint_id}}/withdraw", "host": ["{{base_url}}"], "path": ["complaints", "{{complaint_id}}", "withdraw"] }
          }
        }
      ]
    }
  ]
}
