          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/stats/summary", "host": ["{{base_url}}"], "path": ["stats", "summary"] }
          }
        },
