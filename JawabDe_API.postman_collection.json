            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lat\": 31.5497,\n  \"lon\": 74.3436\n}"
            },
            "url": { "raw": "{{base_url}}/locate", "host": ["{{base_url}}"], "path": ["locate"] }
          }
        },
        {
          "name": "Locate by GPS (Karachi)",
          "request": {
            "method": "POST",
